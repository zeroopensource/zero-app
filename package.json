{
  "name": "@zeroopensource/zero-app-mono",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "publish": "turbo run publish",
    "build": "turbo run build --force",
    "build:android": "turbo run build:android --force",
    "build:desktop": "turbo run build:desktop --force",
    "build:web": "turbo run build:web --force",
    "clean": "turbo run clean",
    "dev": "turbo run dev",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "turbo": "^2.8.12",
    "typescript": "catalog:",
    "ultracite": "7.0.11",
    "@zeroopensource/zero-cli": "latest"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=18"
  }
}
