{
  "name": "zero-app",
  "displayName": "Zero",
  "productName": "Zero",
  "description": "Zero App",
  "version": "0.0.12",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/zeroopensource/zero-app"
  },
  "private": true,
  "author": "ZeroOpenSource",
  "main": "src-electron/main.js",
  "scripts": {
    "clean": "rimraf out out-electron out-capacitor",
    "shadcn": "shadcn",
    "shadcn:addzero": "pnpm shadcn add https://zerocn.zeroopensource.org/r/all.json -y -o",
    "dev:web": "dotenv -e .env -- next dev",
    "build:web": "next build && tsx scripts/fix-next-out.ts && pnpm sync:android",
    "serve:web": "serve out",
    "start:web": "dotenv -e .env -- next start",
    "open:android": "pnpm build:web && cap open android",
    "dev:android": "pnpm build:web && cap run android",
    "build:android": "pnpm clean && pnpm build:android:apk && pnpm build:android:aab && pnpm move:capacitor-outputs",
    "build:android:aab": "pnpm build:web && cross-env RELEASE_TYPE=AAB cap build android",
    "build:android:apk": "pnpm build:web && cross-env RELEASE_TYPE=APK cap build android",
    "open:ios": "pnpm build:web && cap open ios",
    "dev:ios": "pnpm build:web && cap run ios",
    "build:ios": "pnpm build:web && cap build ios",
    "start:forge": "electron-forge start",
    "package:forge": "electron-forge package",
    "dev:desktop": "concurrently -n \"NEXT,ELECTRON\" -c \"yellow,blue\" --kill-others \"pnpm dev:web\" \"electron .\"",
    "build:desktop": "pnpm clean && pnpm build:web && electron-forge make",
    "publish:desktop": "electron-forge publish",
    "sign:windows": "node src-electron/sign.mjs",
    "rebuild:windows": "cd node_modules/electron && node install.js && cd ../electron-winstaller && node script/select-7z-arch.js",
    "rebuild:macos": "node-gyp rebuild --directory node_modules/macos-alias && node-gyp rebuild --directory node_modules/fs-xattr",
    "sync:android": "cap sync && node src-capacitor/sync-android-version.mjs",
    "move:capacitor-outputs": "node src-capacitor/move-capacitor-outputs.mjs",
    "generate:cap:icon": "pnpx @capacitor/assets generate --iconBackgroundColor #09090b --iconBackgroundColorDark #09090b --splashBackgroundColor #09090b --splashBackgroundColorDark #09090b --assetPath /src-capacitor/assets",
    "temp:build:electronbuilder": "pnpm build:web && electron-builder"
  },
  "dependencies": {
    "@electron/windows-sign": "^2.0.2",
    "@capacitor/android": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/ios": "^8.1.0",
    "@giscus/react": "^3.1.0",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@tanstack/react-form": "^1.27.3",
    "@zeroopensource/zero-cli": "^0.0.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "better-auth": "^1.4.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "dotenv-expand": "^12.0.3",
    "electron-serve": "^3.0.1",
    "electron-squirrel-startup": "^1.0.1",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.546.0",
    "nanoid": "^5.1.6",
    "next": "^16.1.1",
    "next-themes": "^0.4.6",
    "radix-ui": "1.4.3",
    "react": "catalog:",
    "react-day-picker": "^9.13.0",
    "react-dom": "catalog:",
    "react-resizable-panels": "^4.4.2",
    "recharts": "2.15.4",
    "shadcn": "^3.7.0",
    "sonner": "^2.0.5",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.3.4",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "fs-xattr": "0.3.1",
    "@electron-forge/maker-msix": "^7.11.1",
    "@electron-forge/publisher-github": "^7.11.1",
    "@electron-forge/maker-wix": "^7.11.1",
    "@capacitor/cli": "^8.1.0",
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-appx": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron/build-tools": "^2.1.5",
    "@electron/fuses": "^1.8.0",
    "@tailwindcss/postcss": "^4.1.10",
    "@types/node": "^20",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "cross-env": "10.1.0",
    "dotenv-cli": "11.0.0",
    "electron": "^40.6.1",
    "serve": "^14.2.5",
    "tailwindcss": "^4.1.10",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "@zeroopensource/zero-cli": "latest",
    "sharp": "^0.34.5",
    "@capacitor/assets": "^3.0.5"
  }
}
