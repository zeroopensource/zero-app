{
  "name": "@zeroopensource/zero-app-v2",
  "displayName": "Zero",
  "description": "Open Source App",
  "version": "0.0.8",
  "private": true,
  "author": "Zero <zeroopensource@gmail.com>",
  "main": "src-electron/main.js",
  "scripts": {
    "dev:desktop": "concurrently -n \"NEXT,ELECTRON\" -c \"yellow,blue\" --kill-others \"pnpm dev:web\" \"electron .\"",
    "build": "pnpm build:web && electron-builder",
    "dev2": "concurrently \"pnpm dev:web\" \"pnpm dev:desktop\"",
    "dev:web": "dotenv -e .env -- next dev",
    "build:web": "cross-env PLATFORM=web next build && pnpm fix:next-out && cap sync",
    "serve:web": "serve out",
    "fix:next-out": "tsx scripts/fix-next-out.ts",
    "start": "dotenv -e .env -- next start",
    "shadcn": "shadcn",
    "shadcn:addzero": "pnpm shadcn add https://zerocn.zeroopensource.org/r/all.json -y -o",
    "cap": "cap",
    "open:android": "pnpm build:web && cap open android",
    "dev:android": "pnpm build:web && cap run android",
    "open:ios": "pnpm build:web && cap open ios",
    "dev:ios": "pnpm build:web && cap run ios",
    "install:electron": "node node_modules/electron/install.js",
    "generate:cap:icon": "pnpx @capacitor/assets generate --iconBackgroundColor #09090b --iconBackgroundColorDark #09090b --splashBackgroundColor #09090b --splashBackgroundColorDark #09090b --assetPath /src-capacitor/assets"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/ios": "^8.1.0",
    "@giscus/react": "^3.1.0",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@tanstack/react-form": "^1.27.3",
    "@zeroopensource/zero-cli": "^0.0.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "better-auth": "^1.4.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "dotenv-expand": "^12.0.3",
    "electron-serve": "^3.0.1",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.546.0",
    "nanoid": "^5.1.6",
    "next": "^16.1.1",
    "next-themes": "^0.4.6",
    "radix-ui": "1.4.3",
    "react": "catalog:",
    "react-day-picker": "^9.13.0",
    "react-dom": "catalog:",
    "react-resizable-panels": "^4.4.2",
    "recharts": "2.15.4",
    "shadcn": "^3.7.0",
    "sonner": "^2.0.5",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.3.4",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.1.0",
    "@tailwindcss/postcss": "^4.1.10",
    "@types/node": "^20",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "cross-env": "10.1.0",
    "dotenv-cli": "11.0.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "serve": "^14.2.5",
    "tailwindcss": "^4.1.10",
    "tsx": "^4.21.0",
    "typescript": "catalog:"
  }
}
